# Copie para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env.

# Z-API (WhatsApp) — painel Z-API > Instancia / Security
ZAPI_INSTANCE_ID=your-zapi-instance-id
ZAPI_TOKEN=your-zapi-token
ZAPI_CLIENT_TOKEN=your-zapi-client-token

# Groq (IA) — console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# Dashboard de metricas (WebApp)
DASHBOARD_API_KEY=your-dashboard-api-key-min-32-chars

# Telefone do atendente para alertas (DDI + DDD + numero, sem + ou espacos)
ATTENDANT_PHONE=5511999999999
